# hledger CSV import rules for bank_export.csv
# Generated by AI, run deterministically every time

source bank_export.csv

skip 1

fields date, description, amount, balance

date-format %Y-%m-%d

currency EUR

account1 assets:checking

# Categorize expenses by description patterns
if albert heijn
  account2 expenses:food:groceries
  comment groceries

if power co
  account2 expenses:utilities:electricity
  comment electricity bill

if restaurant
  account2 expenses:food:dining-out
  comment dining out

if salary
  account2 income:salary
  comment monthly salary
